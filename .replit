modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/hasahisawi: حصاحيصاوي"

[[workflows.workflow]]
name = "artifacts/hasahisawi: حصاحيصاوي"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=20706 pnpm --filter @workspace/hasahisawi run dev"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN = "hasahisawi.firebaseapp.com"
EXPO_PUBLIC_FIREBASE_PROJECT_ID = "hasahisawi"
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET = "hasahisawi.firebasestorage.app"
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID = "133656291161"
EXPO_PUBLIC_FIREBASE_APP_ID = "1:133656291161:web:7d0a88a80d3be1af418e48"
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID = "G-8NDWWB1735"
EXPO_PUBLIC_FIREBASE_API_KEY = "AIzaSyC0o8hr3Dp0hgqKovIDUM0PSCbqgBABvx8"

[nix]
channel = "stable-25_05"
packages = ["jdk17", "gh"]
