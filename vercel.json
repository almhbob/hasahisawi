{
  "version": 2,
  "buildCommand": "cd artifacts/api-server && pnpm install && pnpm run build",
  "outputDirectory": "artifacts/api-server/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "vercel-handler.mjs": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/vercel-handler.mjs"
    }
  ]
}