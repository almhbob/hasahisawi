{
  "version": 2,
  "installCommand": "npm install --no-package-lock && npm install --no-package-lock --include=dev --prefix artifacts/api-server",
  "buildCommand": "node artifacts/api-server/build-vercel.mjs",
  "functions": {
    "api/server.mjs": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/server"
    }
  ]
}
