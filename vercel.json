{
  "version": 2,
  "buildCommand": "pnpm -r --filter \"./artifacts/api-server\" run build",
  "outputDirectory": "artifacts/api-server/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "index.mjs": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/index.mjs" },
    { "source": "/health", "destination": "/index.mjs" },
    { "source": "/(.*)", "destination": "/index.mjs" }
  ]
}
