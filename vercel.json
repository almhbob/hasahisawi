{
  "version": 2,
  "buildCommand": "pnpm -r --filter \"./artifacts/api-server\" run build",
  "functions": {
    "artifacts/api-server/dist/index.mjs": {
      "runtime": "vercel-node@latest"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/artifacts/api-server/dist/index.mjs" }
  ]
}
