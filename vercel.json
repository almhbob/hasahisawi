{
  "version": 2,
  "installCommand": "npm install --no-package-lock && npm install --no-package-lock --prefix artifacts/api-server",
  "buildCommand": "npm run vercel-build",
  "functions": {
    "api/server.mjs": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/server" }
  ]
}
