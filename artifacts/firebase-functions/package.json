{
  "name": "@workspace/firebase-functions",
  "version": "1.0.0",
  "private": true,
  "description": "Firebase Cloud Functions — Hasahisawi API",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "bcryptjs": "3.0.3",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "express": "4.21.2",
    "firebase-admin": "13.4.0",
    "firebase-functions": "6.3.2",
    "multer": "^2.1.1",
    "openai": "^4.103.0",
    "pg": "8.16.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.11",
    "typescript": "^5.4.2"
  }
}
