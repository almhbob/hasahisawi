{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/hasahisawi run build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @workspace/hasahisawi run serve",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
